{{if not batteries:}}
<div class="export-notfound">No Batteries</div>
{{else:}}
<h3 class="export-h3">Batteries</h3>
<div class="table export-table">
{{for battery in batteries:}}
<div class="row export-row">
    <div class="col export-field_name">{{=battery.battery.name}}</div>
    <div class="col export-field_value">{{=battery.quantity}} needed</div>
</div>
{{pass}}
</div>
{{pass}}